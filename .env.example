PORT=3000
NODE_ENV=production
LOG_LEVEL=info

GITHUB_APP_ID=123456
GITHUB_PRIVATE_KEY_PATH=/absolute/path/to/private-key.pem
# For hosted deployments, prefer an escaped single-line PEM:
# GITHUB_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\n...\n-----END RSA PRIVATE KEY-----"
GITHUB_WEBHOOK_SECRET=replace-me
GITHUB_OWNER=your-github-username

GROQ_API_KEY=gsk_replace_me
GROQ_MODEL=llama-3.3-70b-versatile

UPSTASH_REDIS_REST_URL=https://example.upstash.io
UPSTASH_REDIS_REST_TOKEN=replace-me

MAX_FILES=20
MAX_COMMENTS=12
COMMENT_ON_CLEAN=false

# Optional SecOps webhook alerts. Supports Discord or Slack incoming webhooks.
SECURITY_ALERT_WEBHOOK_URL=
SECURITY_ALERT_PROVIDER=auto
SECURITY_ALERT_MIN_SEVERITY=high
DISABLE_STALE_PR_REMINDER=false

# Local dashboard OAuth and API wiring.
GITHUB_OAUTH_CLIENT_ID=
GITHUB_OAUTH_CLIENT_SECRET=
APP_BASE_URL=http://localhost:3001
DASHBOARD_URL=http://localhost:3000/dashboard
DASHBOARD_CORS_ORIGINS=http://localhost:3000
SESSION_SECRET=replace-me
DASHBOARD_ALLOWED_GITHUB_LOGINS=
